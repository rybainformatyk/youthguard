<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4A90E2" 
    android:padding="24dp">

    <ImageView
        android:id="@+id/alertIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:src="@android:drawable/ic_dialog_info"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/alertTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/alertIcon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="Opiekun jest z Tobą!"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/alertMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/alertTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="Twój opiekun został poinformowany i jest gotowy, by Ci pomóc.\n\nJeśli czujesz się niepewnie, zakończ rozmowę."
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textAlignment="center"
        android:lineSpacingExtra="8dp"/>

    <Button
        android:id="@+id/dismissAlertBtn"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:text="ZROZUMIAŁEM"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#4A90E2"
        android:backgroundTint="#FFFFFF"
        app:cornerRadius="16dp"/>

</RelativeLayout>