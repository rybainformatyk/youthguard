<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true">

    <!-- Header z marginesami -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:textColor="@color/primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YouthGuard"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/historyCardBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/card_background"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_stroke">
            <ImageButton
                android:id="@+id/historyBtn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_recent_history"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"> <!-- Marginesy boczne dla całej treści -->

            <!-- MAIN CONTROL PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_stroke"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardBackgroundColor="@color/black"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/mic_idle"
                        android:id="@+id/indicatorContainer"
                        android:layout_marginBottom="16dp">
                        <View
                            android:id="@+id/micIndicator"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:background="@drawable/mic_dot"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SYSTEM GOTOWY"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="24dp"/>

                    <Button
                        android:id="@+id/startBtn"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="INICJUJ OCHRONĘ"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:backgroundTint="@color/button_background"
                        android:textColor="@color/white"
                        app:cornerRadius="16dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/primary"/>

                    <TextView
                        android:id="@+id/warningText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/mic_idle"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CONTEXTUAL MONITORING CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_stroke"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONITOROWANIE ROZMOWY NA ŻYWO"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/speechText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Oczekiwanie na sygnał..."
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:minLines="3"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GUARDIANS SECTION HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ZAUFANI OPIEKUNOWIE"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/guardiansRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/settingsBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="KONFIGURACJA SYSTEMU"
                android:backgroundTint="@color/black"
                android:textColor="@color/text_secondary"
                app:cornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_stroke"
                android:layout_marginBottom="100dp"/>
                
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addGuardianFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        app:fabCustomSize="64dp"
        app:maxImageSize="32dp"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"
        app:srcCompat="@android:drawable/ic_input_add" />

</RelativeLayout>
